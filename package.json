{
  "name": "mac-terminal",
  "version": "6.1.0-0",
  "description": "Control the macOS Terminal app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/mac-terminal.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./source/index.js"
    }
  },
  "files": [
    "source",
    "types"
  ],
  "scripts": {
    "prebuild": "rm -fr types",
    "build": "tsc",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint",
    "lint:fix": "eslint --fix",
    "prepack": "npm run build",
    "quality:check": "npm run lint:check && npm run format:check && npm run types:check && npm run unused:check",
    "quality:fix": "npm run lint:fix && npm run format:fix",
    "test": "node --experimental-test-module-mocks --test",
    "test:coverage": "npm run test -- --experimental-test-coverage",
    "types:check": "tsc --noEmit",
    "unused:check": "knip"
  },
  "dependencies": {
    "bplist-parser": "^0.3.2",
    "ow": "^3.1.1",
    "run-applescript": "^7.0.0"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-plugin-package-json": "^1.4.0",
    "knip": "^6.4.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "xo": "^3.0.2"
  },
  "engines": {
    "node": ">=22 <=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node"
    },
    "packageManager": {
      "name": "npm",
      "version": "^11.16"
    }
  },
  "os": [
    "darwin"
  ],
  "allowScripts": {
    "unrs-resolver": false
  }
}
