{
  "name": "mac-terminal",
  "version": "5.0.0",
  "description": "Control the macOS Terminal app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/mac-terminal.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com>",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "eslint": "eslint --cache",
    "format:check": "npm run prettier -- --check",
    "format:fix": "npm run prettier -- --write",
    "lint:check": "npm run eslint",
    "lint:fix": "npm run eslint -- --fix",
    "prettier": "prettier --cache .",
    "quality:check": "npm run format:check && npm run lint:check && npm run unused:check",
    "quality:fix": "npm run format:fix && npm run lint:fix",
    "unused:check": "knip"
  },
  "dependencies": {
    "bplist-parser": "^0.3.2",
    "ps-list": "^9.0.0",
    "run-applescript": "^7.0.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^0.91.0",
    "knip": "^5.86.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "xo": "^2.0.2"
  },
  "engines": {
    "node": ">=20 <=24"
  },
  "os": [
    "darwin"
  ]
}
