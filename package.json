{
  "name": "mac-terminal",
  "version": "6.1.0-0",
  "description": "Control the macOS Terminal app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrik-csak/mac-terminal.git"
  },
  "license": "MIT",
  "author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./source/index.js"
    }
  },
  "files": [
    "source",
    "types"
  ],
  "scripts": {
    "_eslint": "eslint --cache --cache-strategy=content",
    "_knip": "knip --cache",
    "_prettier": "prettier --cache .",
    "build": "tsc",
    "format:check": "npm run _prettier -- --check",
    "format:fix": "npm run _prettier -- --write",
    "lint:check": "npm run _eslint",
    "lint:fix": "npm run _eslint -- --fix",
    "prepack": "npm run build",
    "quality:check": "npm run lint:check && npm run format:check && npm run unused:check",
    "quality:fix": "npm run lint:fix && npm run format:fix && npm run unused:fix",
    "test": "node --experimental-test-module-mocks --test",
    "test:coverage": "node --experimental-test-coverage --experimental-test-module-mocks --test",
    "unused:check": "npm run _knip",
    "unused:fix": "npm run _knip -- --fix"
  },
  "dependencies": {
    "bplist-parser": "^0.3.2",
    "ow": "^3.1.1",
    "run-applescript": "^7.0.0"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-package-json": "^0.91.0",
    "knip": "^6.4.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.2",
    "xo": "^2.0.2"
  },
  "engines": {
    "node": ">=22 <=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.10.0"
    }
  },
  "os": [
    "darwin"
  ]
}
